# Discord channel
SCOTTY_DISCORD_ENABLED=0
# Bot token from Discord Developer Portal -> Bot -> Reset Token
SCOTTY_DISCORD_BOT_TOKEN=
# Optional allow-lists. Use * only for local testing.
SCOTTY_DISCORD_ALLOW_GUILDS=
SCOTTY_DISCORD_ALLOW_CHANNELS=
SCOTTY_DISCORD_ALLOW_FROM=
# Require @mention in guild channels (DMs always route)
SCOTTY_DISCORD_MENTION_ONLY=1
# Deterministic smoke-test shortcut: "hello scotty" -> hello reply
SCOTTY_DISCORD_HELLO_WORLD_ENABLED=1

# Gmail tool plugin (OAuth 2.0 — create client at https://console.cloud.google.com/apis/credentials)
# On-demand tools: search, read, readAttachment, label — no polling
SCOTTY_GMAIL_ENABLED=0
# From Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client ID (Desktop or Web)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Web client only: must match an authorized redirect URI in the console
SCOTTY_GMAIL_OAUTH_REDIRECT_URI=http://127.0.0.1:18789/oauth/gmail/callback
# Where refresh/access tokens are stored after first CLI auth (default: under workspace)
SCOTTY_GMAIL_CREDENTIALS_PATH=
# Comma-separated Gmail API scopes (uncomment and adjust if needed)
# SCOTTY_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.modify

# Brain (Cursor SDK)
CURSOR_API_KEY=
SCOTTY_CURSOR_MODEL=composer-2.5
SCOTTY_CURSOR_STREAM_LOG=1
SCOTTY_CURSOR_CWD=
SCOTTY_CURSOR_PROMPT=
SCOTTY_CURSOR_RESUME_PROMPT=
SCOTTY_CURSOR_RUNTIME=node
SCOTTY_NODE_BIN=
SCOTTY_BRAIN=cursor
# Local whisper.cpp transcription for WhatsApp voice notes (run `bun run whisper:model` first)
SCOTTY_WHISPER_BIN=
SCOTTY_WHISPER_MODEL=
# Optional: whatsapp:image=image,whatsapp=whatsapp,whatsapp:audio=audio
SCOTTY_BRAIN_SKILL_MAP=
